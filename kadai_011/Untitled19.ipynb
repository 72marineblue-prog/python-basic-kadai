      "source": [
        "# リスト反復可能オブジェクト\n",
        "array = [\"水\",\"金\",\"地\",\"火\",\"木\",\"土\",\"天\",\"海\",\"冥\"]\n",
        "\n",
        "for planet in array:\n",
        "    print(planet)\n",
        "\n",
        "\n",
        "# インデックスの初期化\n",
        "i = 0\n",
        "\n",
        "while i < len(array):\n",
        "    print(array[i])\n",
        "\n",
        "# 無限ループを防ぎ次の要素に進める\n",
        "    i += 1"
      ],
